<Page x:Class="Lumpix.Movement.Calculator.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Lumpix.Movement.Calculator"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Label Content="Movement Calculator" Grid.Column="0" Grid.ColumnSpan="6" Grid.Row="0" FontSize="32" VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <Button Grid.Column="1" Grid.Row="2" Margin="10" FontSize="16" Background="Transparent" BorderBrush="black" BorderThickness="1" Click="btn_uniform_motion_click" >
            <TextBlock Text="uniform motion" TextWrapping="Wrap" TextAlignment="Center"/>
        </Button>

        <Button  Grid.Column="4" Grid.Row="2" Margin="10" FontSize="16" Background="Transparent" BorderBrush="black" BorderThickness="1" Click="btn_accelerated_motion_click">
            <TextBlock Text="accelerated motion" TextWrapping="Wrap" TextAlignment="Center"/>
        </Button>

        <Button Grid.Column="1" Grid.Row="4" Margin="10" FontSize="16" Background="Transparent" BorderBrush="black" BorderThickness="1" Click="btn_circle_motion_click">
            <TextBlock Text="circle motion" TextWrapping="Wrap" TextAlignment="Center"/>
        </Button>

        <Button Grid.Column="4" Grid.Row="4" Margin="10" FontSize="16" Background="Transparent" BorderBrush="black" BorderThickness="1" Click="btn_swing_motion_click">
            <TextBlock Text="swing motion" TextWrapping="Wrap" TextAlignment="Center"/>
        </Button>

        <Label Content="by Lumpix" Grid.Column="5" Grid.Row="5" FontSize="10" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
    </Grid>
</Page>
